# 使用輕量版 Python
FROM python:3.9-slim

WORKDIR /app

# 複製並安裝套件
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# 複製所有程式碼
COPY . .

# 開放 8080 Port
EXPOSE 8080

# 啟動 Streamlit，並強制綁定在 8080 Port
CMD ["streamlit", "run", "dashboard.py", "--server.port=8080", "--server.address=0.0.0.0"]